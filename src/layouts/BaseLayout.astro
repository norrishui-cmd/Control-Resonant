---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { alternatesFor, type Locale } from '../data/localized';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  ogImage?: string;
  jsonLd?: unknown;
  noindex?: boolean;
  canonicalPath?: string;
  lang?: Locale;
}

const { title, description, ogType = 'website', ogImage = '/og.png', jsonLd, noindex = false, canonicalPath, lang = 'en' } = Astro.props;

const site = Astro.site ?? new URL('https://controlresonant.wiki');
const canonical = new URL(canonicalPath ?? Astro.url.pathname, site).href;
const ogImageURL = new URL(ogImage, site).href;
const siteName = 'Control Resonant Field Guide';
const alternatePaths = alternatesFor(Astro.url.pathname);
const ogLocales = { en: 'en_US', de: 'de_DE', fr: 'fr_FR' };
const skip = { en: 'Skip to content', de: 'Zum Inhalt springen', fr: 'Aller au contenu' };
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-adsense-account" content="ca-pub-9505220977121599" />
    <link rel="canonical" href={canonical} />
    {alternatePaths && Object.entries(alternatePaths).map(([code, path]) => <link rel="alternate" hreflang={code} href={new URL(path, site).href} />)}
    {alternatePaths && <link rel="alternate" hreflang="x-default" href={new URL(alternatePaths.en, site).href} />}
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large'} />
    <meta name="theme-color" content="#0a0a0c" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocales[lang]} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Google AdSense: loaded once here so every current and future route inherits it. -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9505220977121599"
      crossorigin="anonymous"
    ></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="flex min-h-screen flex-col font-body antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-3 focus:top-3 focus:z-50 focus:bg-resonant focus:px-3 focus:py-2 focus:font-mono focus:text-xs focus:text-void"
    >
      {skip[lang]}
    </a>
    <Header lang={lang} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

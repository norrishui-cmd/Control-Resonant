---
import BaseLayout from '../layouts/BaseLayout.astro';
import { databaseCopy, type DatabaseLocale } from '../data/databaseLocalized';
const { lang } = Astro.props as { lang: DatabaseLocale };
const copy = databaseCopy[lang];
const records = copy.groups.flatMap(group => group.records);
const jsonLd = {'@context':'https://schema.org','@graph':[{'@type':'CollectionPage',name:copy.heading,url:`https://controlresonant.wiki${copy.path}`,inLanguage:lang,dateModified:'2026-07-19',mainEntity:{'@type':'ItemList',numberOfItems:records.length,itemListElement:records.map((record,i)=>({'@type':'ListItem',position:i+1,name:record[0],url:`https://controlresonant.wiki${record[4]}`}))}},{'@type':'BreadcrumbList',itemListElement:[{'@type':'ListItem',position:1,name:lang==='de'?'Startseite':'Accueil',item:`https://controlresonant.wiki/${lang}/`},{'@type':'ListItem',position:2,name:copy.heading,item:`https://controlresonant.wiki${copy.path}`}]}]};
---
<BaseLayout lang={lang} title={`${copy.title} | Field Guide`} description={copy.description} canonicalPath={copy.path} jsonLd={jsonLd}>
  <header class="border-b border-ash-700"><div class="wrap py-14"><p class="eyebrow">{copy.eyebrow}</p><h1 class="mt-3 font-display text-3xl font-bold text-bone sm:text-4xl">{copy.heading}</h1><p class="mt-4 max-w-3xl leading-relaxed text-bone-dim">{copy.intro}</p><p class="mt-4 font-mono text-xs uppercase tracking-wider text-ash-400">{copy.reviewed}</p><div class="mt-6 flex flex-wrap gap-3"><span class="stamp stamp--confirmed">{copy.tracked}</span><span class="stamp stamp--preview">{copy.prerelease}</span></div></div></header>
  <div class="wrap py-12"><nav class="mb-10 flex flex-wrap gap-2" aria-label={copy.heading}>{copy.groups.map((group,i)=><a href={`#group-${i}`} class="border border-ash-700 px-3 py-2 font-mono text-xs uppercase tracking-wider text-ash-300 hover:border-resonant hover:text-bone">{group.title} · {group.records.length}</a>)}</nav>
    {copy.groups.map((group,i)=><section id={`group-${i}`} class="mb-14 scroll-mt-24"><div class="mb-5"><h2 class="font-display text-2xl font-bold text-bone">{group.title}</h2><p class="mt-2 text-sm text-bone-dim">{group.summary}</p></div><div class="overflow-x-auto border border-ash-700"><table class="w-full min-w-[44rem] text-left text-sm"><thead class="bg-ash-900 font-mono text-[.65rem] uppercase tracking-wider text-ash-300"><tr><th class="p-3">{copy.record}</th><th class="p-3">{copy.type}</th><th class="p-3">{copy.state}</th><th class="p-3">{copy.detail}</th></tr></thead><tbody class="divide-y divide-ash-800">{group.records.map(record=><tr class="align-top"><td class="p-3"><a href={record[4]} class="font-semibold text-resonant hover:text-hiss">{record[0]}</a></td><td class="p-3 text-bone-dim">{record[1]}</td><td class="p-3 font-mono text-xs text-clearance">{record[2]}</td><td class="p-3 leading-relaxed text-bone-dim">{record[3]}</td></tr>)}</tbody></table></div></section>)}
    <aside class="border border-ash-700 bg-ash-900/40 p-6"><h2 class="font-display text-xl font-bold text-bone">{copy.rule}</h2><p class="mt-3 max-w-3xl text-sm leading-relaxed text-bone-dim">{copy.ruleText}</p></aside>
  </div>
</BaseLayout>

---
import { faqsForTab, faqTabLabels, type FaqTab } from '../data/faqs';
const {tab,lang='en'}=Astro.props as {tab:FaqTab;lang?:'en'|'de'|'fr'};
const items=faqsForTab(tab).slice(0,5);
const labels={en:{eye:'Player questions',heading:`${faqTabLabels[tab]} FAQ`,all:'Browse all 50 FAQs',read:'Full answer'},de:{eye:'Spielerfragen',heading:`FAQ: ${faqTabLabels[tab]}`,all:'Alle 50 FAQs',read:'Vollständige Antwort'},fr:{eye:'Questions des joueurs',heading:`FAQ : ${faqTabLabels[tab]}`,all:'Voir les 50 FAQ',read:'Réponse complète'}}[lang];
---
<section class="border-t border-ash-700" aria-labelledby={`faq-${tab}`}><div class="wrap py-14"><div class="flex items-end justify-between gap-4"><div><p class="eyebrow">{labels.eye}</p><h2 id={`faq-${tab}`} class="mt-2 font-display text-2xl font-bold text-bone">{labels.heading}</h2></div><a href={`/faq/#${tab}`} class="hidden font-mono text-xs uppercase tracking-[.14em] text-resonant hover:text-hiss sm:block">{labels.all} →</a></div><div class="mt-7 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">{items.map(item=><article class="flex flex-col border border-ash-700 bg-ash-900/30 p-4"><h3 class="font-display text-base font-semibold leading-snug text-bone"><a href={`/faq/${item.slug}/`} class="hover:text-resonant">{item.question}</a></h3><p class="mt-3 flex-1 text-sm leading-relaxed text-ash-300">{item.answer}</p><a href={`/faq/${item.slug}/`} class="mt-4 font-mono text-[.65rem] uppercase tracking-[.12em] text-resonant">{labels.read} →</a></article>)}</div><a href={`/faq/#${tab}`} class="mt-5 inline-block font-mono text-xs uppercase tracking-[.12em] text-resonant sm:hidden">{labels.all} →</a></div></section>

---
import { newsForTab, tabLabels, type NewsTab } from '../data/news';
const { tab, lang = 'en' } = Astro.props as { tab: NewsTab; lang?: 'en'|'de'|'fr' };
const items = newsForTab(tab);
const labels = {
  en:{eyebrow:'Latest field reports',heading:`${tabLabels[tab]} news`,all:'All news',read:'Read report'},
  de:{eyebrow:'Aktuelle Meldungen',heading:`News: ${tabLabels[tab]}`,all:'Alle News',read:'Meldung lesen'},
  fr:{eyebrow:'Dernières actualités',heading:`Actualités : ${tabLabels[tab]}`,all:'Toutes les actualités',read:'Lire l’article'}
}[lang];
---
<section class="border-t border-ash-700 bg-ash-950/35" aria-labelledby={`news-${tab}`}>
  <div class="wrap py-14">
    <div class="flex items-end justify-between gap-4"><div><p class="eyebrow">{labels.eyebrow}</p><h2 id={`news-${tab}`} class="mt-2 font-display text-2xl font-bold text-bone">{labels.heading}</h2></div><a href={`/news/#${tab}`} class="hidden font-mono text-xs uppercase tracking-[.14em] text-resonant hover:text-hiss sm:block">{labels.all} →</a></div>
    <div class="mt-7 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">{items.map(item => <article class="flex flex-col border border-ash-700 bg-ash-900/35 p-4"><p class="font-mono text-[.62rem] uppercase tracking-[.12em] text-ash-400"><time datetime={item.date}>{item.date}</time></p><h3 class="mt-2 font-display text-base font-semibold leading-snug text-bone"><a href={`/news/${item.slug}/`} class="hover:text-resonant">{item.title}</a></h3><p class="mt-3 flex-1 text-sm leading-relaxed text-ash-300">{item.description}</p><a href={`/news/${item.slug}/`} class="mt-4 font-mono text-[.65rem] uppercase tracking-[.12em] text-resonant hover:text-hiss">{labels.read} →</a></article>)}</div>
  </div>
</section>

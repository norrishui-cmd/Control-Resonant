---
import { alternatesFor, type Locale } from '../data/localized';
const { lang = 'en' } = Astro.props as { lang?: Locale };
const path = Astro.url.pathname;
const norm = (p: string) => (p !== '/' && p.endsWith('/') ? p.slice(0, -1) : p);
const cur = norm(path);
const isActive = (href: string) => {
  const h = norm(href);
  return ['/', '/de', '/fr'].includes(h) ? cur === h : cur === h || cur.startsWith(h + '/');
};

const navs = {
en: [
  { href: '/', label: 'Home' },
  { href: '/release-date/', label: 'Release Date' },
  { href: '/guides/', label: 'Guides' },
  { href: '/database/', label: 'Database' },
  { href: '/guides/characters-and-story/', label: 'Characters' },
  { href: '/guides/platforms-and-performance/', label: 'Platforms' },
  { href: '/faq/', label: 'FAQ' },
],
de: [{href:'/de/',label:'Start'},{href:'/de/erscheinungsdatum/',label:'Release'},{href:'/de/datenbank/',label:'Datenbank'},{href:'/de/kampfsystem-und-builds/',label:'Kampf'},{href:'/de/sprachen/',label:'Sprachen'},{href:'/faq/',label:'FAQ'}],
fr: [{href:'/fr/',label:'Accueil'},{href:'/fr/date-de-sortie/',label:'Sortie'},{href:'/fr/base-de-donnees/',label:'Données'},{href:'/fr/combat-et-builds/',label:'Combat'},{href:'/fr/langues/',label:'Langues'},{href:'/faq/',label:'FAQ'}],
};
const nav = navs[lang];
const alternates = alternatesFor(path) ?? {en:'/',de:'/de/',fr:'/fr/'};
const menu = {en:'Menu',de:'Menü',fr:'Menu'};
const tag = {en:'Unofficial Field Guide',de:'Inoffizieller Field Guide',fr:'Guide non officiel'};
const languageLabel = {en:'Language',de:'Sprache',fr:'Langue'};
const languageNames = {en:'English',de:'Deutsch',fr:'Français'};
---
<header class="sticky top-0 z-40 border-b border-ash-700 bg-void/90 backdrop-blur">
  <div class="wrap flex items-center justify-between gap-4 py-3">
    <a href={lang === 'en' ? '/' : `/${lang}/`} class="group flex items-center gap-3" aria-label="Control Resonant Field Guide — home">
      <svg
        width="26"
        height="26"
        viewBox="0 0 32 32"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        class="text-hiss transition-transform group-hover:rotate-90"
        aria-hidden="true"
      >
        <path d="M16 4 a12 12 0 0 1 10.4 18" />
        <path d="M16 28 a12 12 0 0 1 -10.4 -18" />
        <path d="M16 10 a6 6 0 0 1 4.5 10" />
        <path d="M16 22 a6 6 0 0 1 -4.5 -10" />
        <line x1="16" y1="28" x2="16" y2="32" />
      </svg>
      <span class="leading-none">
        <span class="block font-display text-[0.92rem] font-bold tracking-[0.16em] text-bone">CONTROL RESONANT</span>
        <span class="mt-0.5 block font-mono text-[0.58rem] uppercase tracking-[0.22em] text-ash-400">{tag[lang]}</span>
      </span>
    </a>

    <!-- desktop -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        nav.map((i) => (
          <a
            href={i.href}
            aria-current={isActive(i.href) ? 'page' : undefined}
            class={`px-3 py-2 font-mono text-xs uppercase tracking-[0.14em] transition-colors ${
              isActive(i.href) ? 'text-hiss' : 'text-ash-300 hover:text-bone'
            }`}
          >
            {i.label}
          </a>
        ))
      }
      <details class="group relative ml-2 border-l border-ash-700 pl-3" aria-label={languageLabel[lang]}>
        <summary class="flex cursor-pointer list-none items-center gap-2 border border-ash-600 px-3 py-2 font-mono text-[.65rem] uppercase tracking-[.12em] text-bone hover:border-resonant">
          <span aria-hidden="true">◎</span><span>{languageNames[lang]}</span><span class="text-ash-400 transition-transform group-open:rotate-180">▾</span>
        </summary>
        <div class="absolute right-0 top-full z-50 mt-2 w-44 border border-ash-700 bg-ash-900 p-1 shadow-xl">
          <p class="px-3 py-2 font-mono text-[.58rem] uppercase tracking-[.16em] text-ash-500">{languageLabel[lang]}</p>
          {(['en','de','fr'] as const).map(code => <a href={alternates[code]} hreflang={code} lang={code} aria-current={lang === code ? 'page' : undefined} class={`flex items-center justify-between px-3 py-2 font-mono text-xs ${lang === code ? 'bg-ash-800 text-resonant' : 'text-bone-dim hover:bg-ash-800 hover:text-bone'}`}><span>{languageNames[code]}</span><span class="uppercase text-ash-500">{code}</span></a>)}
        </div>
      </details>
    </nav>

    <!-- mobile -->
    <details class="relative md:hidden">
      <summary class="flex cursor-pointer list-none items-center gap-2 border border-ash-600 px-3 py-2 font-mono text-xs uppercase tracking-[0.14em] text-bone">
        {menu[lang]}
      </summary>
      <nav class="absolute right-0 z-50 mt-2 w-52 border border-ash-700 bg-ash-900 p-1 shadow-xl" aria-label="Primary mobile">
        {
          nav.map((i) => (
            <a
              href={i.href}
              aria-current={isActive(i.href) ? 'page' : undefined}
              class={`block px-3 py-2 font-mono text-xs uppercase tracking-[0.14em] transition-colors ${
                isActive(i.href) ? 'text-hiss' : 'text-bone-dim hover:bg-ash-800 hover:text-bone'
              }`}
            >
              {i.label}
            </a>
          ))
        }
        <details class="mt-1 border-t border-ash-700 pt-1" aria-label={languageLabel[lang]}>
          <summary class="cursor-pointer list-none px-3 py-2 font-mono text-xs uppercase tracking-[.12em] text-bone">◎ {languageLabel[lang]} · {languageNames[lang]} ▾</summary>
          <div class="border-t border-ash-800">{(['en','de','fr'] as const).map(code => <a href={alternates[code]} hreflang={code} lang={code} aria-current={lang === code ? 'page' : undefined} class={`flex justify-between px-4 py-2 font-mono text-xs ${lang === code ? 'bg-ash-800 text-resonant' : 'text-ash-300 hover:text-bone'}`}><span>{languageNames[code]}</span><span class="uppercase">{code}</span></a>)}</div>
        </details>
      </nav>
    </details>
  </div>
</header>

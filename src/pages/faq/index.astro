---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {faqItems,faqsForTab,faqTabLabels,type FaqTab} from '../../data/faqs';
const tabs=Object.keys(faqTabLabels) as FaqTab[];
const jsonLd={'@context':'https://schema.org','@type':'FAQPage',mainEntity:faqItems.map(item=>({'@type':'Question',name:item.question,acceptedAnswer:{'@type':'Answer',text:item.answer}}))};
---
<BaseLayout title="Control Resonant FAQ: 50 Confirmed Answers" description="50 source-checked Control Resonant answers covering release date, gameplay, characters, platforms, languages, editions, and support." jsonLd={jsonLd}>
<header class="border-b border-ash-700"><div class="wrap py-14"><p class="eyebrow">Question archive</p><h1 class="mt-3 font-display text-4xl font-bold text-bone">Control Resonant FAQ</h1><p class="mt-4 max-w-3xl leading-relaxed text-bone-dim">Fifty direct, source-checked answers. Every question has its own permanent URL, official evidence, and a route back to the relevant guide.</p><nav class="mt-7 flex flex-wrap gap-2">{tabs.map(tab=><a href={`#${tab}`} class="border border-ash-700 px-3 py-2 font-mono text-xs uppercase tracking-[.12em] text-ash-300 hover:border-resonant">{faqTabLabels[tab]} · 10</a>)}</nav></div></header>
<div class="wrap py-12">{tabs.map(tab=><section id={tab} class="mb-14 scroll-mt-24"><div class="mb-5 flex items-center gap-3"><h2 class="font-display text-2xl font-bold text-bone">{faqTabLabels[tab]}</h2><span class="h-px flex-1 bg-ash-700"></span><span class="font-mono text-xs text-ash-500">10 ANSWERS</span></div><div class="grid gap-3 lg:grid-cols-2">{faqsForTab(tab).map(item=><details id={item.slug} class="group scroll-mt-24 border border-ash-700 bg-ash-900/25 p-5"><summary class="cursor-pointer list-none font-display text-lg font-semibold text-bone group-open:text-resonant">{item.question}</summary><p class="mt-4 text-sm leading-relaxed text-bone-dim">{item.answer}</p><div class="mt-4 flex flex-wrap gap-4 font-mono text-[.65rem] uppercase tracking-[.1em]"><a href={`/faq/${item.slug}/`} class="text-resonant">Permanent answer →</a><a href={item.sourceUrl} target="_blank" rel="nofollow noopener" class="text-ash-400 hover:text-bone">Official source ↗</a></div></details>)}</div></section>)}</div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {faqItems,faqTabLabels} from '../../data/faqs';
export function getStaticPaths(){return faqItems.map(item=>({params:{slug:item.slug},props:{item}}));}
const {item}=Astro.props;const related=faqItems.filter(f=>f.tab===item.tab&&f.slug!==item.slug).slice(0,4);const url=`https://controlresonant.wiki/faq/${item.slug}/`;
const jsonLd={'@context':'https://schema.org','@graph':[{'@type':'FAQPage',mainEntity:[{'@type':'Question',name:item.question,acceptedAnswer:{'@type':'Answer',text:`${item.answer} ${item.detail}`}}]},{'@type':'BreadcrumbList',itemListElement:[{'@type':'ListItem',position:1,name:'Home',item:'https://controlresonant.wiki/'},{'@type':'ListItem',position:2,name:'FAQ',item:'https://controlresonant.wiki/faq/'},{'@type':'ListItem',position:3,name:item.question,item:url}]}]};
---
<BaseLayout title={`${item.question} | Control Resonant FAQ`} description={item.answer} jsonLd={jsonLd}><article><header class="border-b border-ash-700"><div class="wrap py-12"><nav class="font-mono text-[.66rem] uppercase tracking-[.14em] text-ash-400"><a href="/">Home</a> / <a href="/faq/">FAQ</a> / {faqTabLabels[item.tab]}</nav><p class="eyebrow mt-6">Verified answer</p><h1 class="mt-3 max-w-4xl font-display text-3xl font-bold leading-tight text-bone sm:text-5xl">{item.question}</h1></div></header><div class="wrap grid gap-12 py-12 lg:grid-cols-[minmax(0,44rem)_1fr]"><div class="prose-doc"><section class="border-l-4 border-clearance bg-ash-900/40 p-5"><h2 class="!mt-0 !border-0 !p-0">Quick answer</h2><p class="!mb-0 mt-3">{item.answer}</p></section><h2>What this means</h2><p>{item.detail}</p><h2>Official source</h2><p><a href={item.sourceUrl} target="_blank" rel="nofollow noopener">{item.sourceLabel}</a></p><h2>Continue with the relevant guide</h2><p><a href={item.relatedUrl}>Open the related Control Resonant guide</a> for the current topic summary, connected systems, and any later verified changes.</p><p class="text-sm text-ash-400">This answer is reviewed against pre-release official information. It states unknown boundaries explicitly and will be revised when Remedy or a first-party store publishes a newer fact.</p></div><aside><div class="sticky top-24 border border-ash-700 bg-ash-900/30 p-5"><p class="eyebrow">Related questions</p><ul class="mt-4 space-y-4">{related.map(f=><li><a href={`/faq/${f.slug}/`} class="font-display text-sm font-semibold text-bone hover:text-resonant">{f.question}</a></li>)}</ul><a href={`/faq/#${item.tab}`} class="mt-6 block border-t border-ash-700 pt-4 font-mono text-xs uppercase tracking-[.12em] text-resonant">All {faqTabLabels[item.tab]} FAQs →</a></div></aside></div></article></BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusStamp from '../../components/StatusStamp.astro';
import { databaseGroups, databaseRecords } from '../../data/database';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', name: 'Control Resonant Game Database', url: 'https://controlresonant.wiki/database/', dateModified: '2026-07-19', mainEntity: { '@type': 'ItemList', numberOfItems: databaseRecords.length, itemListElement: databaseRecords.map((item, i) => ({ '@type': 'ListItem', position: i + 1, name: item.name, url: `https://controlresonant.wiki${item.href}` })) } },
    { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://controlresonant.wiki/' }, { '@type': 'ListItem', position: 2, name: 'Database', item: 'https://controlresonant.wiki/database/' }] },
  ],
};
---
<BaseLayout title="Control Resonant Database: Characters, Items & Gameplay" description="A verified Control Resonant game database covering confirmed characters, the Aberrant, Artifacts, edition items, special gameplay, enemies, demo status and release data." jsonLd={jsonLd}>
  <header class="border-b border-ash-700"><div class="wrap py-14">
    <p class="eyebrow">FBC // Live Intelligence Index</p>
    <h1 class="mt-3 font-display text-3xl font-bold text-bone sm:text-4xl">Control Resonant Game Database</h1>
    <p class="mt-4 max-w-3xl leading-relaxed text-bone-dim">A structured index of what Remedy and platform holders have actually disclosed. Every row links to a fuller canonical guide instead of creating duplicate thin pages. Last evidence review: <strong class="text-bone">July 19, 2026</strong>.</p>
    <div class="mt-6 flex flex-wrap gap-3"><span class="stamp stamp--confirmed">{databaseRecords.length} tracked records</span><span class="stamp stamp--preview">Pre-release data</span></div>
  </div></header>
  <div class="wrap py-12">
    <nav class="mb-10 flex flex-wrap gap-2" aria-label="Database categories">{databaseGroups.map(group => <a href={`#${group.id}`} class="border border-ash-700 px-3 py-2 font-mono text-xs uppercase tracking-wider text-ash-300 hover:border-resonant hover:text-bone">{group.title} · {group.records.length}</a>)}</nav>
    {databaseGroups.map(group => <section id={group.id} class="mb-14 scroll-mt-24">
      <div class="mb-5"><p class="eyebrow">Attribute class</p><h2 class="mt-2 font-display text-2xl font-bold text-bone">{group.title}</h2><p class="mt-2 text-sm text-bone-dim">{group.summary}</p></div>
      <div class="overflow-x-auto border border-ash-700"><table class="w-full min-w-[44rem] text-left text-sm"><thead class="bg-ash-900 font-mono text-[.65rem] uppercase tracking-wider text-ash-300"><tr><th class="p-3">Record</th><th class="p-3">Type</th><th class="p-3">Evidence state</th><th class="p-3">Verified detail</th></tr></thead><tbody class="divide-y divide-ash-800">{group.records.map(record => <tr class="align-top"><td class="p-3"><a class="font-semibold text-resonant hover:text-hiss" href={record.href}>{record.name}</a></td><td class="p-3 text-bone-dim">{record.type}</td><td class="p-3 font-mono text-xs text-clearance">{record.status}</td><td class="p-3 leading-relaxed text-bone-dim">{record.detail}</td></tr>)}</tbody></table></div>
    </section>)}
    <aside class="border border-ash-700 bg-ash-900/40 p-6"><h2 class="font-display text-xl font-bold text-bone">Coverage rule</h2><p class="mt-3 max-w-3xl text-sm leading-relaxed text-bone-dim">A name appearing only in rumor, fan discussion or an unlabeled trailer frame does not become a database entity. New character, item, enemy and ability pages are added only when an official source identifies the subject and provides enough distinct information to answer a real search query. Unknown values remain visibly unknown.</p></aside>
  </div>
</BaseLayout>

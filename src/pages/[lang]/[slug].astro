---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localizedPages, pathFor } from '../../data/localized';
import NewsModule from '../../components/NewsModule.astro';
export function getStaticPaths() { return localizedPages.map(page => ({params:{lang:page.lang,slug:page.slug},props:{page}})); }
const { page } = Astro.props;
const related = localizedPages.filter(p => p.lang === page.lang && p.slug !== page.slug).slice(0,3);
const words = page.lang === 'de' ? {home:'Startseite', short:'Kurzantwort', sources:'Offizielle Quellen', related:'Weiterlesen', updated:'Geprüft im Juli 2026 · vor Veröffentlichung'} : {home:'Accueil', short:'Réponse courte', sources:'Sources officielles', related:'À lire ensuite', updated:'Vérifié en juillet 2026 · avant la sortie'};
const canonicalPath = `/${page.lang}/${page.slug}/`;
const newsTab = page.englishPath === '/release-date/' ? 'release' : page.englishPath === '/guides/characters-and-story/' ? 'characters' : page.englishPath === '/guides/platforms-and-performance/' || page.englishPath === '/guides/system-requirements/' || page.englishPath === '/guides/language-support/' ? 'platforms' : page.englishPath === '/guides/combat-and-build-systems-explained/' ? 'guides' : null;
const jsonLd = {'@context':'https://schema.org','@graph':[{'@type':'Article',headline:page.title,description:page.description,inLanguage:page.lang,mainEntityOfPage:`https://controlresonant.wiki${canonicalPath}`},{'@type':'BreadcrumbList',itemListElement:[{'@type':'ListItem',position:1,name:words.home,item:`https://controlresonant.wiki/${page.lang}/`},{'@type':'ListItem',position:2,name:page.title,item:`https://controlresonant.wiki${canonicalPath}`}]}]};
---
<BaseLayout lang={page.lang} title={`${page.title} | Field Guide`} description={page.description} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <article><header class="border-b border-ash-700"><div class="wrap py-12"><nav class="font-mono text-xs text-ash-400"><a href={`/${page.lang}/`} class="hover:text-resonant">{words.home}</a> / {page.label}</nav><p class="eyebrow mt-6">{page.label}</p><h1 class="mt-3 max-w-4xl font-display text-3xl font-bold leading-tight text-bone sm:text-5xl">{page.title}</h1><p class="mt-5 max-w-3xl text-lg leading-relaxed text-bone-dim">{page.description}</p><p class="mt-5 font-mono text-[.65rem] uppercase tracking-[.14em] text-ash-400">{words.updated}</p></div></header>
    <div class="wrap grid gap-12 py-12 lg:grid-cols-[minmax(0,44rem)_1fr]"><div class="prose-doc"><section class="border-l-4 border-clearance bg-ash-900/50 p-5"><h2 class="!mt-0 !border-0 !p-0">{words.short}</h2><p class="!mb-0 mt-3">{page.answer}</p></section>
      {page.sections.map(section => <section><h2>{section.heading}</h2>{section.paragraphs.map(p => <p>{p}</p>)}{section.bullets && <ul>{section.bullets.map(item => <li>{item}</li>)}</ul>}</section>)}
      <section><h2>{words.sources}</h2><ul>{page.sources.map(s => <li><a href={s.url} rel="nofollow noopener" target="_blank">{s.label}</a></li>)}</ul></section>
    </div><aside><div class="sticky top-24 border border-ash-700 bg-ash-900/35 p-5"><p class="eyebrow">{words.related}</p><ul class="mt-4 space-y-4">{related.map(p => <li><a href={pathFor(p,page.lang)} class="font-display text-sm font-semibold text-bone hover:text-resonant">{p.title}</a></li>)}</ul></div></aside></div>
  </article>
  {newsTab && <NewsModule tab={newsTab} lang={page.lang} />}
</BaseLayout>

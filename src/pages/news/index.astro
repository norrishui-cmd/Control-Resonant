---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { newsItems, newsForTab, tabLabels, type NewsTab } from '../../data/news';
const tabs = Object.keys(tabLabels) as NewsTab[];
const jsonLd={'@context':'https://schema.org','@type':'CollectionPage',name:'Control Resonant News',description:'Officially sourced Control Resonant release, gameplay, character, platform and development updates.',url:'https://controlresonant.wiki/news/',numberOfItems:newsItems.length};
---
<BaseLayout title="Control Resonant News & Official Updates" description="Track 25 officially sourced Control Resonant updates across release date, gameplay systems, characters, platforms, and Remedy development news." jsonLd={jsonLd}>
  <header class="border-b border-ash-700"><div class="wrap py-14"><p class="eyebrow">News desk</p><h1 class="mt-3 font-display text-4xl font-bold text-bone">Control Resonant News</h1><p class="mt-4 max-w-3xl leading-relaxed text-bone-dim">Dated, source-linked reports built from Remedy, PlayStation, and official storefront information. News records what changed; evergreen guides carry the latest player answer.</p><nav class="mt-7 flex flex-wrap gap-2" aria-label="News categories">{tabs.map(tab => <a href={`#${tab}`} class="border border-ash-700 px-3 py-2 font-mono text-xs uppercase tracking-[.12em] text-ash-300 hover:border-resonant hover:text-bone">{tabLabels[tab]} · 5</a>)}</nav></div></header>
  <div class="wrap py-12">{tabs.map(tab => <section id={tab} class="mb-14 scroll-mt-24"><div class="mb-5 flex items-center gap-3"><h2 class="font-display text-2xl font-bold text-bone">{tabLabels[tab]}</h2><span class="h-px flex-1 bg-ash-700"></span><span class="font-mono text-xs text-ash-500">5 REPORTS</span></div><div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">{newsForTab(tab).map(item => <article class="border border-ash-700 bg-ash-900/30 p-5"><time datetime={item.date} class="font-mono text-[.65rem] uppercase tracking-[.12em] text-ash-400">{item.date}</time><h3 class="mt-2 font-display text-lg font-semibold text-bone"><a href={`/news/${item.slug}/`} class="hover:text-resonant">{item.title}</a></h3><p class="mt-3 text-sm leading-relaxed text-ash-300">{item.description}</p></article>)}</div></section>)}</div>
</BaseLayout>

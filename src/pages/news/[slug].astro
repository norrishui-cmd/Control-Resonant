---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { newsItems, tabLabels } from '../../data/news';
export function getStaticPaths(){return newsItems.map(item=>({params:{slug:item.slug},props:{item}}));}
const {item}=Astro.props;
const related=newsItems.filter(n=>n.tab===item.tab&&n.slug!==item.slug).slice(0,4);
const url=`https://controlresonant.wiki/news/${item.slug}/`;
const jsonLd={'@context':'https://schema.org','@graph':[{'@type':'NewsArticle',headline:item.title,description:item.description,datePublished:item.date,dateModified:item.date,mainEntityOfPage:url,author:{'@type':'Organization',name:'Control Resonant Field Guide'},publisher:{'@type':'Organization',name:'Control Resonant Field Guide'}},{'@type':'BreadcrumbList',itemListElement:[{'@type':'ListItem',position:1,name:'Home',item:'https://controlresonant.wiki/'},{'@type':'ListItem',position:2,name:'News',item:'https://controlresonant.wiki/news/'},{'@type':'ListItem',position:3,name:item.title,item:url}]}]};
---
<BaseLayout title={`${item.title} | Control Resonant News`} description={item.description} ogType="article" jsonLd={jsonLd}>
  <article><header class="border-b border-ash-700"><div class="wrap py-12"><nav class="font-mono text-[.66rem] uppercase tracking-[.14em] text-ash-400"><a href="/" class="hover:text-bone">Home</a> / <a href="/news/" class="hover:text-bone">News</a> / {tabLabels[item.tab]}</nav><p class="eyebrow mt-6">{tabLabels[item.tab]} report</p><h1 class="mt-3 max-w-4xl font-display text-3xl font-bold leading-tight text-bone sm:text-5xl">{item.title}</h1><p class="mt-5 max-w-3xl text-lg leading-relaxed text-bone-dim">{item.description}</p><p class="mt-5 font-mono text-[.65rem] uppercase tracking-[.14em] text-ash-400">Published <time datetime={item.date}>{item.date}</time> · Official-source briefing</p></div></header>
    <div class="wrap grid gap-12 py-12 lg:grid-cols-[minmax(0,44rem)_1fr]"><div class="prose-doc"><p class="text-lg text-bone">{item.lead}</p><h2>What was confirmed</h2>{item.details.map(p=><p>{p}</p>)}<h2>Key takeaways</h2><ul>{item.takeaways.map(point=><li>{point}</li>)}</ul><h2>Official source</h2><p><a href={item.sourceUrl} target="_blank" rel="nofollow noopener">{item.sourceLabel}</a></p><p class="text-sm text-ash-400">This report records the state of official information on its publication date. For changing specifications or launch details, follow the linked topic hub and current first-party listing.</p></div><aside><div class="sticky top-24 border border-ash-700 bg-ash-900/35 p-5"><p class="eyebrow">Related reports</p><ul class="mt-4 space-y-4">{related.map(n=><li><a href={`/news/${n.slug}/`} class="font-display text-sm font-semibold text-bone hover:text-resonant">{n.title}</a></li>)}</ul><a href={`/news/#${item.tab}`} class="mt-6 block border-t border-ash-700 pt-4 font-mono text-xs uppercase tracking-[.12em] text-resonant">All {tabLabels[item.tab]} news →</a></div></aside></div>
  </article>
</BaseLayout>

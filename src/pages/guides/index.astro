---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import NewsModule from '../../components/NewsModule.astro';
import FaqModule from '../../components/FaqModule.astro';

const guides = (await getCollection('guides')).sort(
  (a, b) => a.data.order - b.data.order,
);
const categoryId = (category: string) => category.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

// group by category, preserving order
const groups: { category: string; items: typeof guides }[] = [];
for (const g of guides) {
  let group = groups.find((x) => x.category === g.data.category);
  if (!group) {
    group = { category: g.data.category, items: [] };
    groups.push(group);
  }
  group.items.push(g);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://controlresonant.wiki/' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://controlresonant.wiki/guides/' },
  ],
};
---
<BaseLayout
  title="Control Resonant Guides: Builds, Bosses & Beginner Help"
  description="Every Control Resonant guide in one place — beginner help, combat and build systems, Aberrant weapon forms, and Resonant boss breakdowns."
  jsonLd={jsonLd}
>
  <section class="border-b border-ash-700">
    <div class="wrap py-14">
      <p class="eyebrow">Field Manual</p>
      <h1 class="mt-3 font-display text-3xl font-bold text-bone sm:text-4xl">Control Resonant Guides</h1>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-bone-dim">
        Pre-launch coverage of Remedy's action-RPG sequel. Each file is tagged with a
        verification status so you can tell confirmed detail from preview and speculation.
      </p>
    </div>
  </section>

  <div class="wrap py-12">
    <nav class="mb-12 border border-ash-700 bg-ash-900/30 p-5" aria-label="Guide categories">
      <p class="eyebrow">Browse topics</p>
      <div class="mt-4 flex flex-wrap gap-2">
        {groups.map((group) => (
          <a href={`#${categoryId(group.category)}`} class="border border-ash-700 px-3 py-2 font-mono text-[0.68rem] uppercase tracking-[0.12em] text-ash-300 transition-colors hover:border-resonant hover:text-bone">
            {group.category} · {group.items.length}
          </a>
        ))}
      </div>
    </nav>
    {
      groups.map((group) => (
        <section id={categoryId(group.category)} class="mb-12 scroll-mt-24">
          <div class="mb-5 flex items-center gap-3">
            <h2 class="font-display text-xl font-bold text-bone">{group.category}</h2>
            <span class="h-px flex-1 bg-ash-700"></span>
            <span class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-ash-500">
              {group.items.length} file{group.items.length === 1 ? '' : 's'}
            </span>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {group.items.map((g) => (
              <GuideCard
                title={g.data.title}
                description={g.data.description}
                href={`/guides/${g.id}/`}
                category={g.data.category}
                status={g.data.status}
              />
            ))}
          </div>
        </section>
      ))
    }
  </div>
  <NewsModule tab="guides" />
  <FaqModule tab="guides" />
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusStamp from '../../components/StatusStamp.astro';
import NewsModule from '../../components/NewsModule.astro';
import FaqModule from '../../components/FaqModule.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, status, category, published, updated, indexable, sources } = entry.data;

const url = `https://controlresonant.wiki/guides/${entry.id}/`;
const updatedISO = updated ? updated.toISOString() : undefined;
const publishedISO = published ? published.toISOString() : undefined;
const updatedLabel = updated
  ? updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
const related = (await getCollection('guides'))
  .filter((guide) => guide.id !== entry.id && guide.data.category === category && guide.data.indexable)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
const newsTab = entry.id === 'characters-and-story' ? 'characters' : entry.id === 'platforms-and-performance' ? 'platforms' : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: title,
      description,
      url,
      ...(publishedISO ? { datePublished: publishedISO } : {}),
      ...(updatedISO ? { dateModified: updatedISO } : {}),
      author: { '@type': 'Organization', name: 'Control Resonant Field Guide' },
      publisher: { '@type': 'Organization', name: 'Control Resonant Field Guide' },
      isPartOf: { '@type': 'WebSite', name: 'Control Resonant Field Guide', url: 'https://controlresonant.wiki/' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://controlresonant.wiki/' },
        { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://controlresonant.wiki/guides/' },
        { '@type': 'ListItem', position: 3, name: title, item: url },
      ],
    },
  ],
};
---
<BaseLayout title={`${title} | Control Resonant`} description={description} ogType="article" jsonLd={jsonLd} noindex={!indexable}>
  <article>
    <header class="border-b border-ash-700">
      <div class="wrap py-12">
        <nav class="mb-5 font-mono text-[0.66rem] uppercase tracking-[0.16em] text-ash-400" aria-label="Breadcrumb">
          <a href="/" class="hover:text-bone">Home</a>
          <span class="mx-2 text-ash-600">/</span>
          <a href="/guides/" class="hover:text-bone">Guides</a>
        </nav>

        <div class="mb-4 flex flex-wrap items-center gap-3">
          <span class="eyebrow">{category}</span>
          <StatusStamp status={status} />
        </div>

        <h1 class="max-w-3xl font-display text-3xl font-bold leading-tight text-bone sm:text-4xl">
          {title}
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-bone-dim">{description}</p>

        {
          updatedLabel && (
            <p class="mt-5 font-mono text-[0.62rem] uppercase tracking-[0.14em] text-ash-500">
              Last reviewed {updatedLabel}
            </p>
          )
        }
      </div>
    </header>

    <div class="wrap py-12">
      <div class="prose-doc">
        <Content />
      </div>

      {
        sources.length > 0 && (
          <aside class="mt-12 max-w-[44rem] border border-ash-700 bg-ash-900/40 p-5" aria-labelledby="sources-heading">
            <h2 id="sources-heading" class="font-display text-lg font-semibold text-bone">Official sources</h2>
            <ul class="mt-3 space-y-2 text-sm text-bone-dim">
              {sources.map((source) => (
                <li><a href={source.url} rel="nofollow noopener" class="text-resonant hover:text-hiss">{source.label}</a></li>
              ))}
            </ul>
          </aside>
        )
      }

      {
        related.length > 0 && (
          <nav class="mt-10 max-w-[44rem]" aria-labelledby="related-heading">
            <h2 id="related-heading" class="font-display text-lg font-semibold text-bone">Related guides</h2>
            <ul class="mt-3 grid gap-2 sm:grid-cols-2">
              {related.map((guide) => (
                <li><a href={`/guides/${guide.id}/`} class="block border border-ash-700 p-3 text-sm text-bone-dim transition-colors hover:border-resonant hover:text-bone">{guide.data.title}</a></li>
              ))}
            </ul>
          </nav>
        )
      }

      <div class="mt-12 max-w-[44rem] border-t border-ash-800 pt-6">
        <p class="text-xs leading-relaxed text-ash-400">
          Detail on Control Resonant can change before release. Verify anything time-sensitive
          against Remedy's official channels. See our
          <a href="/about/" class="text-resonant hover:text-hiss">sources &amp; method</a>.
        </p>
        <a href="/guides/" class="mt-4 inline-block font-mono text-xs uppercase tracking-[0.16em] text-resonant hover:text-hiss">
          &larr; Back to all guides
        </a>
      </div>
    </div>
  </article>
  {newsTab && <NewsModule tab={newsTab} />}
  {newsTab && <FaqModule tab={newsTab} />}
</BaseLayout>

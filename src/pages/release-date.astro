---
import BaseLayout from '../layouts/BaseLayout.astro';
import Countdown from '../components/Countdown.astro';
import StatusStamp from '../components/StatusStamp.astro';

const platforms = [
  { name: 'PlayStation 5', note: 'Launch day' },
  { name: 'Xbox Series X / S', note: 'Launch day' },
  { name: 'PC — Steam & Epic Games Store', note: 'Launch day' },
  { name: 'GeForce NOW', note: 'Launch day (streaming)' },
  { name: 'Mac — Steam & App Store', note: 'Later in 2026' },
];

const editions = [
  {
    name: 'Standard Edition',
    items: ['The base game'],
  },
  {
    name: 'Digital Deluxe Edition',
    items: [
      'Base game',
      'AWE Mission Outfit',
      'Untapped Artifact (Wallet)',
      'Starter Resource Bundle',
      'Digital artbook',
      'Original soundtrack',
      '48-hour advance access on PS5',
    ],
  },
];

const preorder = [
  'Hiss Corruption outfit',
  'Occult outfit',
  "Pickpocket's Tool artifact",
];

const faqs = [
  {
    q: 'When is the Control Resonant release date?',
    a: 'Control Resonant launches on September 24, 2026.',
  },
  {
    q: 'What platforms is Control Resonant on?',
    a: 'PlayStation 5, Xbox Series X/S, and PC via Steam and Epic Games Store at launch, plus GeForce NOW. A Mac version on Steam and the App Store arrives later in 2026.',
  },
  {
    q: 'Is there a PS4 or Xbox One version?',
    a: 'No. Control Resonant is a current-generation release, so there are no announced PS4 or Xbox One versions.',
  },
  {
    q: 'Who is publishing Control Resonant?',
    a: 'Remedy Entertainment is self-publishing the game after acquiring full rights to the Control series.',
  },
  {
    q: 'Do I need to play the first Control?',
    a: 'No. Remedy has built Resonant as a standalone story centered on Dylan Faden, so it is approachable for newcomers.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://controlresonant.wiki/' },
        { '@type': 'ListItem', position: 2, name: 'Release Date', item: 'https://controlresonant.wiki/release-date/' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---
<BaseLayout
  title="Control Resonant Release Date, Platforms & Editions"
  description="Control Resonant releases September 24, 2026 on PS5, Xbox Series X/S and PC, with a Mac version later. Full platform list, editions, pre-order bonuses and FAQ."
  jsonLd={jsonLd}
>
  <section class="border-b border-ash-700">
    <div class="wrap py-12">
      <p class="eyebrow">Release Briefing</p>
      <h1 class="mt-3 max-w-3xl font-display text-3xl font-bold leading-tight text-bone sm:text-4xl">
        Control Resonant Release Date, Platforms &amp; Editions
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-bone-dim">
        Everything confirmed about when and where you can play Remedy's sequel — plus the
        details that haven't been locked down yet.
      </p>

      <div class="mt-10 grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <div class="mb-3 flex items-center gap-3">
            <span class="eyebrow">Launch date</span>
            <StatusStamp status="confirmed" />
          </div>
          <p class="font-display text-3xl font-bold text-bone sm:text-4xl">September 24, 2026</p>
          <p class="mt-2 text-sm text-ash-300">Developed and self-published by Remedy Entertainment.</p>
        </div>
        <div class="w-full max-w-md">
          <p class="eyebrow mb-3 text-resonant">Time to launch</p>
          <Countdown />
        </div>
      </div>
    </div>
  </section>

  <div class="wrap py-12">
    <!-- platforms -->
    <section class="mb-14">
      <div class="mb-5 flex items-center gap-3">
        <h2 class="font-display text-xl font-bold text-bone">Platforms</h2>
        <StatusStamp status="confirmed" />
      </div>
      <ul class="divide-y divide-ash-800 border-y border-ash-800">
        {
          platforms.map((p) => (
            <li class="flex items-center justify-between gap-4 py-4">
              <span class="text-bone">{p.name}</span>
              <span class="font-mono text-[0.66rem] uppercase tracking-[0.14em] text-ash-400">{p.note}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- editions -->
    <section class="mb-14">
      <div class="mb-5 flex items-center gap-3">
        <h2 class="font-display text-xl font-bold text-bone">Editions</h2>
        <StatusStamp status="preview" />
      </div>
      <p class="mb-6 max-w-2xl text-sm leading-relaxed text-ash-300">
        Edition contents are based on storefront listings from the reveal and may be adjusted
        before launch.
      </p>
      <div class="grid gap-4 sm:grid-cols-2">
        {
          editions.map((e) => (
            <div class="border border-ash-700 bg-ash-950/40 p-5">
              <h3 class="font-display text-base font-semibold text-bone">{e.name}</h3>
              <ul class="mt-3 space-y-2">
                {e.items.map((it) => (
                  <li class="flex gap-2 text-sm text-bone-dim">
                    <span class="text-hiss">▪</span>
                    <span>{it}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <div class="mt-6 border border-ash-700 bg-ash-900/30 p-5">
        <p class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-resonant">Pre-order bonuses (as listed)</p>
        <ul class="mt-3 flex flex-wrap gap-x-6 gap-y-2">
          {
            preorder.map((it) => (
              <li class="flex gap-2 text-sm text-bone-dim">
                <span class="text-hiss">▪</span>
                <span>{it}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- system requirements -->
    <section class="mb-14">
      <div class="mb-5 flex items-center gap-3">
        <h2 class="font-display text-xl font-bold text-bone">PC System Requirements</h2>
        <StatusStamp status="speculation" />
      </div>
      <div class="border border-dashed border-ash-600 bg-ash-950/30 p-6">
        <p class="text-sm leading-relaxed text-ash-300">
          Remedy has not published official minimum or recommended PC specs for Control Resonant
          yet. We will fill this section in with verified requirements once they are announced —
          rather than guess. Check back closer to launch.
        </p>
      </div>
    </section>

    <!-- faq -->
    <section>
      <h2 class="mb-5 font-display text-xl font-bold text-bone">Frequently Asked Questions</h2>
      <dl class="divide-y divide-ash-800 border-y border-ash-800">
        {
          faqs.map((f) => (
            <div class="py-5">
              <dt class="font-display text-base font-semibold text-bone">{f.q}</dt>
              <dd class="mt-2 max-w-2xl text-sm leading-relaxed text-bone-dim">{f.a}</dd>
            </div>
          ))
        }
      </dl>
    </section>
  </div>
</BaseLayout>
